{
  "respectGitignore": true,
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50",
    "CLAUDE_CODE_ENABLE_PROMPT_SUGGESTION": "true",
    "ENABLE_PROMPT_CACHING_1H": "1"
  },
  "includeCoAuthoredBy": true,
  "outputStyle": "Explanatory-Icons",
  "statusLine": {
    "type": "command",
    "command": "python .claude/statusline.py"
  },
  "language": "日本語",
  "spinnerTipsEnabled": true,
  "alwaysThinkingEnabled": true,
  "promptSuggestionEnabled": true,
  "autoUpdatesChannel": "latest",
  "prefersReducedMotion": false,
  "fallbackModel": ["claude-opus-4-8", "claude-sonnet-4-6", "claude-haiku-4-5"],
  "terminal": {
    "mode": "auto"
  },
  "worktree": {
    "baseRef": "head"
  },
  "hooks": {
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [".claude/claudeos/scripts/hooks/pre-compact.js"]
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [".claude/claudeos/scripts/hooks/session-start.js"]
          },
          {
            "type": "command",
            "command": "node",
            "args": [".claude/claudeos/scripts/hooks/verify-goal-set.js"]
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [".claude/claudeos/scripts/hooks/session-end.js"]
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [".claude/claudeos/scripts/hooks/usage-tracker.js"]
          }
        ]
      },
      {
        "matcher": "TeamCreate",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [".claude/claudeos/scripts/hooks/agent-teams-tracker.js"]
          }
        ]
      },
      {
        "matcher": "SendMessage",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [".claude/claudeos/scripts/hooks/agent-teams-tracker.js"]
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [".claude/claudeos/scripts/hooks/teammate-idle-gate.js"]
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [".claude/claudeos/scripts/hooks/task-created-gate.js"]
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [".claude/claudeos/scripts/hooks/task-completed-gate.js"]
          }
        ]
      }
    ]
  }
}
